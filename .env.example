# Copy this to `.env.local` and fill in to enable optional features.
# `.env.local` is gitignored; values prefixed with VITE_ are bundled into
# the client JS, so don't deploy a public build that contains paid keys.

# Shared (Supabase) mode — leave blank to stay in solo (localStorage) mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
VITE_VAULT_KEY=my-crew

# PSA Public API token (https://www.psacard.com/publicapi). Enables the
# "Add by cert" flow — type a cert number and we pull card + grade
# automatically. Leave blank to disable that button.
VITE_PSA_TOKEN=
